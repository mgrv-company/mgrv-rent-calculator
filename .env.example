# mgrv-rent-check — 환경변수 카탈로그
# 로컬 dev: `.env.local`에 복사 후 값 입력 (.env.local은 git에 안 올라감)
# Prod: GCP Cloud Secret Manager에 등록 후 Cloud Run --update-secrets로 주입

# ─── 외부 공공 API (M1 필수) ──────────────────────────────────────────────────
DATA_GO_KR_API_KEY=
# MOLIT 오피스텔 실거래가. data.go.kr 마이페이지 → 개발계정에서 발급.

VWORLD_API_KEY=
# V-World 지오코딩 + 검색. vworld.kr 마이페이지 → 인증키 발급.

VWORLD_REFERER=https://www.mangrove.city
# V-World 호출 시 Referer 헤더에 박는 도메인. V-World에 등록된 도메인과 일치해야 호출 통과.

# ─── 캐시 (M1 선택 — 미설정 시 InMemory fallback) ──────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── KOSIS 전월세전환율 (M2 이연 — 미설정 시 fallback rate 6.07% 사용) ────────
# KOSIS_API_KEY=

# ─── Sheets A 적재 (Phase 2 — ADC 자동 인증, SA 키 파일 불필요) ───────────────
RENT_LEADS_SHEET_ID=1oa8jnbmYiN4T-5EO1FtOYPoTuvoG9YRHROXlnfXy5C4
RENT_LEADS_SHEET_TAB=계산기_raw
# 로컬 dev: `gcloud auth application-default login` 으로 인증 (1회)
# Prod: Cloud Run runtime SA가 ADC 자동 인증
